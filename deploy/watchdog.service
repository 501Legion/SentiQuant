# live-scheduler-deploy FR-09 — 워치독 (oneshot, timer가 주기 호출)
[Unit]
Description=SentiQuant watchdog — heartbeat stale 감지 시 재시작/알림

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/auto_stock
EnvironmentFile=/home/ubuntu/auto_stock/.env
ExecStart=/home/ubuntu/auto_stock/venv/bin/python scripts/watchdog_check.py --restart
